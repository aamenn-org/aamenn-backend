# Environment Configuration
# Copy this file to .env and fill in your values

# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=aamenn_vault

# JWT Configuration
# For Auth0: https://YOUR_DOMAIN.auth0.com/
# For Clerk: https://YOUR_INSTANCE.clerk.accounts.dev/
# For Supabase: https://YOUR_PROJECT.supabase.co/auth/v1
JWT_ISSUER=https://your-auth-provider.com/
JWT_AUDIENCE=your-api-identifier
# Only needed if not using JWKS (asymmetric keys from provider)
JWT_SECRET=your-jwt-secret-for-symmetric-signing

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# JWKS (JSON Web Key Set) - Recommended for production
# Most OAuth providers expose this endpoint
JWKS_URI=https://your-auth-provider.com/.well-known/jwks.json

# Backblaze B2 Configuration
B2_APPLICATION_KEY_ID=your_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_ID=your_bucket_id
B2_BUCKET_NAME=your_bucket_name

# Signed URL expiration (seconds)
B2_SIGNED_URL_EXPIRATION=300

# B2 Account Storage Limit (in GB) - Default is 10GB for free tier
# Change this if you have a paid plan with more storage
B2_STORAGE_LIMIT_GB=10

# Storage warning threshold (percentage) - Alert when usage exceeds this
STORAGE_WARNING_THRESHOLD=80

# Storage Limit (in GB per user)
STORAGE_LIMIT_GB=1

# SMTP / Email Configuration (for vault password reset OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@aamenn.com

# Vault Reset Configuration
VAULT_RESET_OTP_TTL_SECONDS=600
VAULT_RESET_SESSION_TTL_SECONDS=900

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Redis Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here
CACHE_TTL_ALBUMS=60
CACHE_TTL_FILES=30
CACHE_TTL_STORAGE=60
CACHE_TTL_DUPLICATE=900
